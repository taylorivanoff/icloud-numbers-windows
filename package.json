{
  "name": "icloud-numbers",
  "description": "Use iCloud Numbers in a native Windows application.",
  "author": { "name": "Taylor Ivanoff" },
  "version": "1.0.12",
  "repository": "https://github.com/taylorivanoff/icloud-numbers-windows",
  "main": "main.js",
  "scripts": { "start": "electron .", "release": "electron-builder --win --x64 --publish=never" },
  "build": {
    "appId": "io.github.taylorivanoff.icloud-numbers",
    "productName": "iCloud Numbers",
    "win": { "icon": "icon.png", "target": "nsis" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "include": "installer.nsh", "deleteAppDataOnUninstall": true },
    "publish": { "provider": "github", "owner": "taylorivanoff", "repo": "icloud-numbers-windows" },
    "protocols": { "name": "iCloud Numbers", "schemes": ["icloud-numbers"] }
  },
  "dependencies": { "icloud-windows-base": "^1.0.12", "electron-store": "^8.2.0", "electron-updater": "^6.1.8" },
  "devDependencies": { "electron": "^30.0.3", "electron-builder": "^24.13.3" }
}
